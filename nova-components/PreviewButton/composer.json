{
    "name": "jpeters8889/preview-button",
    "description": "A Laravel Nova field.",
    "keywords": [
        "laravel",
        "nova"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Jpeters8889\\PreviewButton\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jpeters8889\\PreviewButton\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
